{
  "env": {
    "LINEAR_API_KEY": "${LINEAR_API_KEY}",
    "LINEAR_DEFAULT_TEAM": "VAS",
    "LINEAR_DEFAULT_PROJECT": "JIO CX"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/scripts/query_guard.py\" --mode pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/scripts/query_post_hook.py\""
          }
        ]
      }
    ]
  }
}
